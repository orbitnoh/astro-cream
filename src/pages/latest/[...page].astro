---
import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import config from '@/config';
import { isPublicPost } from '@/utils/blog-posts';
import { formatDateLabel, formatDateTimeAttribute } from '@/utils/format-date';

type BlogPost = CollectionEntry<'blog'>;

interface Props {
  page: Page<BlogPost>;
}

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = (await getCollection('blog'))
    .filter(isPublicPost)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return paginate(posts, { pageSize: config.posts.perPage });
}

// https://docs.astro.build/en/guides/routing/#the-page-prop
// https://docs.astro.build/en/reference/routing-reference/#the-pagination-page-prop
const { page } = Astro.props;

function getPageUrl(pageNumber: number): string {
  return pageNumber === 1 ? '/latest' : `/latest/${pageNumber}`;
}

/*
1. The pagination window is the consecutive group of page numbers shown around the current page.
2. In this case, windowSize is 5 and windowOffset is 2, so the window shows two pages before
   the current page, the current page itself, and two pages after it.
3. Always include the first page and the last page in addition to the window.
   This usually shows 7 page numbers in total, but it can show 6 when the first or last page overlaps with the window.
4. Insert an ellipsis when adjacent page numbers differ by more than 1.

When there are 5 or fewer total pages:
1 total page  -> [1]
2 total pages -> 1 [2]
3 total pages -> 1 2 [3]
4 total pages -> 1 2 3 [4]
5 total pages -> 1 2 3 4 [5]

When there are 100 total pages:
Page 1   -> [1] 2 3 4 5 ... 100
Page 2   -> 1 [2] 3 4 5 ... 100
Page 3   -> 1 2 [3] 4 5 ... 100
Page 4   -> 1 2 3 [4] 5 6 ... 100
Page 5   -> 1 ... 3 4 [5] 6 7 ... 100
Page 6   -> 1 ... 4 5 [6] 7 8 ... 100

Page 95  -> 1 ... 93 94 [95] 96 97 ... 100
Page 96  -> 1 ... 94 95 [96] 97 98 ... 100
Page 97  -> 1 ... 95 96 [97] 98 99 100
Page 98  -> 1 ... 96 97 [98] 99 100
Page 99  -> 1 ... 96 97 98 [99] 100
Page 100 -> 1 ... 96 97 98 99 [100]
*/

type PaginationItem =
  | {
      type: 'page';
      pageNumber: number;
    }
  | {
      type: 'ellipsis';
    };

function buildPaginationItems(currentPage: number, lastPage: number): PaginationItem[] {
  if (lastPage <= 5) {
    return Array.from({ length: lastPage }, (_, index) => ({
      type: 'page' as const,
      pageNumber: index + 1,
    }));
  }

  const windowSize = 5;
  const windowOffset = 2;
  const windowStartPageNumber = Math.min(
    Math.max(1, currentPage - windowOffset),
    lastPage - windowSize + 1,
  );
  const windowEndPageNumber = Math.min(windowStartPageNumber + windowSize - 1, lastPage);
  const paginationNumber: number[] = [];

  for (let pageNumber = windowStartPageNumber; pageNumber <= windowEndPageNumber; pageNumber++) {
    paginationNumber.push(pageNumber);
  }

  if (paginationNumber[0] !== 1) {
    paginationNumber.unshift(1);
  }

  if (paginationNumber[paginationNumber.length - 1] !== lastPage) {
    paginationNumber.push(lastPage);
  }

  const result: PaginationItem[] = [];

  paginationNumber.forEach((pageNumber, index) => {
    if (index > 0 && pageNumber - paginationNumber[index - 1] > 1) {
      result.push({ type: 'ellipsis' });
    }

    result.push({ type: 'page', pageNumber });
  });

  return result;
}

const paginationItems = buildPaginationItems(page.currentPage, page.lastPage);
---

<DefaultLayout activeLinkIndex={2} title="날짜별">
  <div class="latest-content">
    <section class="intro">
      <span class="intro__eyebrow">Latest</span>
      <h1 class="intro__title">
        최신 글을 먼저 보고<br />
        흐름을 빠르게 따라가세요.
      </h1>
      <p class="intro__description">새로 발행한 글부터 차례대로 확인할 수 있습니다.</p>
    </section>

    <section class="posts">
      <h2 class="posts__title">글 목록</h2>
      <ol class="posts__list">
        {
          page.data.map((post, index) => (
            <li class="posts__item">
              <a class="posts__link" href={`/posts/${post.data.slug}`}>
                <span class="posts__index">
                  {String(page.total - page.start - index).padStart(3, '0')}
                </span>
                <time class="posts__date" datetime={formatDateTimeAttribute(post.data.date)}>
                  {formatDateLabel(post.data.date)}
                </time>
                <span class="posts__post-title">{post.data.title}</span>
              </a>
            </li>
          ))
        }
      </ol>

      <nav class="pagination" aria-label="pagination">
        <ol class="pagination__list">
          {
            paginationItems.map((item) => (
              <li class="pagination__item">
                {item.type === 'page' && item.pageNumber !== page.currentPage && (
                  <a class="pagination__link" href={getPageUrl(item.pageNumber)}>
                    {item.pageNumber}
                  </a>
                )}
                {item.type === 'page' && item.pageNumber === page.currentPage && (
                  <span class="pagination__link pagination__link--current" aria-current="page">
                    {item.pageNumber}
                  </span>
                )}
                {item.type === 'ellipsis' && (
                  <span class="pagination__ellipsis" aria-hidden="true">
                    &hellip;
                  </span>
                )}
              </li>
            ))
          }
        </ol>
      </nav>
    </section>
  </div>
</DefaultLayout>

<style lang="scss">
  .latest-content {
    padding: $space-12 0;

    @include media-down('lg') {
      padding: $space-8 0;
    }
  }

  .intro {
    &__eyebrow {
      display: block;
      color: var(--text-muted);
      font-weight: $font-weight-semibold;
      font-size: $font-size-14;
      line-height: $line-height-tight;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    &__title {
      margin-top: $space-3;
      font-size: $font-size-32;

      @include media-down('md') {
        font-size: $font-size-26;
      }

      @include media-down('sm') {
        margin-top: $space-2;
        font-size: $font-size-24;
      }
    }

    &__description {
      margin-top: $space-5;
      color: var(--text-muted);

      @include media-down('sm') {
        margin-top: $space-3;
      }
    }
  }

  .posts {
    $self: &;

    margin-top: $space-10;
    border-top: 1px solid var(--border);

    &__title {
      padding: $space-4 0;
      border-bottom: 1px solid var(--border);
      font-size: $font-size-14;
    }

    &__link {
      $transition-shift-distance: 3px;

      display: grid;
      grid-template-columns: $space-10 $space-20 minmax(0, 1fr);
      gap: $space-4;
      align-items: center;
      padding: $space-4 $space-3;
      border-bottom: 1px solid color-mix(in srgb, var(--border) 70%, #fff 30%);
      transition: all $transition-duration-1;

      &:hover {
        background-color: var(--bg-surface);
        box-shadow: inset 3px 0 0 var(--accent);

        #{$self}__index {
          color: var(--accent);
          transform: translateX($transition-shift-distance);
        }

        #{$self}__date {
          transform: translateX($transition-shift-distance);
        }

        #{$self}__post-title {
          color: var(--text-heading);
          transform: translateX($transition-shift-distance);
        }
      }

      @include media-down('sm') {
        grid-template-columns: $space-8 minmax(0, 1fr);
        gap: $space-2 $space-3;
        padding: $space-3;
      }
    }

    &__index {
      color: var(--marker);
      font-weight: $font-weight-medium;
      font-size: $font-size-12;
      line-height: $line-height-tight;
      transition: all $transition-duration-1;
    }

    &__date {
      color: var(--text-muted);
      font-weight: $font-weight-medium;
      font-size: $font-size-13;
      line-height: $line-height-tight;
      transition: all $transition-duration-1;

      @include media-down('sm') {
        grid-column: 2;
      }
    }

    &__post-title {
      @include text-ellipsis;

      min-width: 0;
      color: var(--text-heading);
      font-weight: $font-weight-semibold;
      font-size: $font-size-16;
      line-height: $line-height-tight;
      transition: all $transition-duration-1;

      @include media-down('sm') {
        grid-column: 2;
      }
    }
  }

  .pagination {
    margin-top: $space-10;

    &__list {
      display: flex;
      gap: $space-2;
      justify-content: center;
      align-items: center;
    }

    &__link,
    &__ellipsis {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-width: $space-9;
      height: $space-9;
      color: var(--text-muted);
      font-size: $font-size-14;
      line-height: $line-height-none;
    }

    &__link {
      transition: all $transition-duration-1;

      &:not(&--current):hover {
        background-color: color-mix(in srgb, var(--accent) 10%, transparent);
        color: var(--accent);
      }

      &--current {
        background-color: var(--accent);
        color: var(--bg);
        font-weight: $font-weight-semibold;
        cursor: default;
      }
    }

    &__ellipsis {
      min-width: $space-6;
      cursor: default;
    }
  }
</style>
